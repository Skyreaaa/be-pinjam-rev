# Backend (Fly.io) env vars

# Database (Railway MySQL)
DB_HOST=containers-us-west-123.railway.app
DB_USER=railway
DB_PASSWORD=your-db-password
DB_DATABASE=pinjam_kuy
DB_PORT=3306

# JWT secret untuk auth
JWT_SECRET=please-change-this-to-a-long-random-string

# Port akan diinject oleh Fly.io. Jangan paksa PORT manual.
# PORT=8080

# CORS: daftar origin yang diizinkan (pisahkan dengan koma)
# Contoh: domain Netlify Anda dan lokal dev
CORS_ORIGINS=https://your-netlify-site.netlify.app,http://localhost:3000

# Optional: jika ingin pindahkan upload ke Cloudinary agar tidak hilang di Fly.io
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key


# flyctl secrets set `
# DB_HOST=containers-xxx.railway.app `
# DB_USER=railway `
# DB_PASSWORD=YOUR_DB_PASSWORD `
# DB_DATABASE=pinjam_kuy `
# DB_PORT=3306 `
# JWT_SECRET=CHANGE_ME_TO_LONG_RANDOM `
# CORS_ORIGINS=https://your-netlify-site.netlify.app,http://localhost:3000 `
# CLOUDINARY_CLOUD_NAME=your_cloud `
# CLOUDINARY_API_KEY=your_key `
# CLOUDINARY_API_SECRET=your_secret# CLOUDINARY_API_SECRET=your-api-secret
